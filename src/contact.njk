permalink: /contact.html
title: お問い合わせ
activePage: contact
---

    <!-- Page Header -->
    <section class="pt-32 pb-16 bg-gradient-to-br from-orange-50 to-white relative overflow-hidden">
        <div class="absolute right-0 top-0 w-96 h-96 bg-orange-100/30 rounded-full -mr-48"></div>
        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-3xl">
                <div class="inline-block mb-6">
                    <span class="px-4 py-2 bg-white text-primary font-semibold rounded-full text-sm border-2 border-orange-100">Contact</span>
                </div>
                <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">お問い合わせ</h1>
                <p class="text-xl text-gray-600 leading-relaxed">
                    お気軽にご相談ください。<br>経験豊富なスタッフが丁寧に対応いたします。
                </p>
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <section class="py-24 bg-white">
        <div class="container mx-auto px-4">
            <div class="max-w-3xl mx-auto">
                <div class="bg-white rounded-3xl border-2 border-gray-100 shadow-xl p-10">
                    <form class="space-y-6">
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-3">お名前 *</label>
                                <input type="text" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent transition">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-3">フリガナ *</label>
                                <input type="text" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent transition">
                            </div>
                        </div>
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-3">メールアドレス *</label>
                                <input type="email" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent transition">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-3">電話番号 *</label>
                                <input type="tel" required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent transition">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-3">お問い合わせ種別 *</label>
                            <select required class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent transition">
                                <option value="">選択してください</option>
                                <option>物件購入+リノベーション</option>
                                <option>リノベーション済み物件</option>
                                <option>売買仲介</option>
                                <option>資産活用相談</option>
                                <option>その他</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-3">お問い合わせ内容 *</label>
                            <textarea required rows="6" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent transition" placeholder="ご質問やご相談内容をご記入ください"></textarea>
                        </div>
                        <div class="flex items-start gap-3">
                            <input type="checkbox" required class="mt-1 w-5 h-5 text-primary border-gray-300 rounded focus:ring-primary">
                            <label class="text-sm text-gray-600"><a href="/privacy.html" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">プライバシーポリシー</a>に同意する</label>
                        </div>
                        <button type="submit" class="w-full py-5 bg-primary text-white rounded-full font-bold hover:bg-orange-600 transition text-lg shadow-lg">送信する</button>
                    </form>
                </div>

                <!-- Contact Info -->
                <div class="mt-12 grid md:grid-cols-2 gap-6">
                    <div class="bg-gradient-to-br from-orange-50 to-white p-8 rounded-3xl border-2 border-orange-100">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900">お電話</h3>
                        </div>
                        <a href="tel:0120-000-0000" class="text-2xl font-bold text-primary hover:text-orange-600 transition">0120-000-0000</a>
                        <p class="text-sm text-gray-600 mt-2">営業時間: 9:00-18:00（定休日: 水曜日）</p>
                    </div>
                    <div class="bg-gradient-to-br from-yellow-50 to-white p-8 rounded-3xl border-2 border-yellow-100">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 bg-secondary/20 rounded-xl flex items-center justify-center">
                                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900">ご来店</h3>
                        </div>
                        <p class="text-gray-700 leading-relaxed mb-2">〒000-0000<br>東京都○○区○○ 1-2-3<br>○○ビル 4F</p>
                        <a href="/company.html" class="text-primary font-semibold hover:underline text-sm">地図を見る →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
