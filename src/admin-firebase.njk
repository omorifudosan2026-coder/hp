---
layout: admin.njk
permalink: /admin.html
title: 管理画面 | 大森不動産
pageScript: js/admin-firebase.js
bodyClass: bg-cream min-h-screen
---

    <!-- Busy overlay（保存中など操作ロック） -->
    <div id="admin-busy-overlay" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/25 backdrop-blur-[1px]">
        <div class="bg-white border border-[var(--color-border)] px-6 py-4 shadow-[0_12px_40px_rgba(26,26,26,0.10)]">
            <div class="flex items-center gap-3">
                <span class="loading" aria-hidden="true"></span>
                <p id="admin-busy-text" class="text-sm text-ink">保存中...</p>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header class="bg-cream">
        <div class="max-w-7xl mx-auto px-6 md:px-10 py-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="section-label mb-2">Admin</p>
                    <h1 class="font-serif text-2xl text-ink">
                        <span class="text-primary">大森不動産</span> 管理画面
                    </h1>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-muted" id="user-email"></span>
<a href="/" class="site-btn site-btn--compact site-btn--outline-ink">
                        <span class="site-btn__inner">公開サイトへ</span>
                    </a>
                    <button id="logout-btn" class="site-btn site-btn--compact site-btn--outline-muted">
                        <span class="site-btn__inner">ログアウト</span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Navigation Tabs -->
    <div class="bg-cream">
        <div class="max-w-7xl mx-auto px-6 md:px-10">
            <nav class="flex gap-8">
                <button onclick="switchTab('news')" id="tab-news" class="tab-btn cursor-pointer py-4 border-b-2 border-primary text-primary font-medium">ブログ管理</button>
                <button onclick="switchTab('works')" id="tab-works" class="tab-btn cursor-pointer py-4 border-b-2 border-transparent text-muted hover:text-primary transition-colors">施工事例管理</button>
                <button onclick="switchTab('masters')" id="tab-masters" class="tab-btn cursor-pointer py-4 border-b-2 border-transparent text-muted hover:text-primary transition-colors">マスタ管理</button>
            </nav>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-10 py-8">
        <!-- News Tab -->
        <div id="content-news" class="tab-content">
            <div class="bg-white p-6 mb-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="font-serif text-2xl text-ink">ブログ一覧</h2>
                    <button onclick="openNewsModal()" class="site-btn site-btn--md site-btn--primary">
                        <span class="site-btn__inner">＋ 新規追加</span>
                    </button>
                </div>
                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3 mb-5">
                    <div class="flex flex-col md:flex-row md:items-center gap-2 w-full lg:max-w-3xl">
                        <input id="admin-news-search" type="search" placeholder="検索（タイトル/本文）" class="w-full px-4 py-2 border border-[var(--color-border)] bg-white">
                        <select id="admin-news-category" class="w-full md:w-44 px-4 py-2 border border-[var(--color-border)] bg-white">
                            <option value="__all">すべて</option>
                        </select>
                        <button id="admin-news-clear" type="button" class="site-btn site-btn--md site-btn--outline-muted min-w-28">
                            <span class="site-btn__inner">クリア</span>
                        </button>
                    </div>
                </div>
                <div id="news-list" class="divide-y divide-[var(--color-border)]"><div class="text-center py-8 text-gray-500">読み込み中...</div></div>
                <div id="admin-news-pager" class="hidden mt-5 flex items-center justify-end gap-3 text-sm text-muted">
                    <button id="admin-news-prev" type="button" class="site-btn site-btn--compact site-btn--outline-muted"><span class="site-btn__inner">前へ</span></button>
                    <span id="admin-news-page-label" class="tabular-nums">1 / 1</span>
                    <button id="admin-news-next" type="button" class="site-btn site-btn--compact site-btn--outline-muted"><span class="site-btn__inner">次へ</span></button>
                </div>
            </div>
        </div>
        <!-- Works Tab -->
        <div id="content-works" class="tab-content hidden">
            <div class="bg-white p-6 mb-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="font-serif text-2xl text-ink">施工事例一覧</h2>
                    <button onclick="openWorkModal()" class="site-btn site-btn--md site-btn--primary">
                        <span class="site-btn__inner">＋ 新規追加</span>
                    </button>
                </div>
                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3 mb-5">
                    <div class="flex flex-col md:flex-row md:items-center gap-2 w-full lg:max-w-3xl">
                        <input id="admin-works-search" type="search" placeholder="検索（タイトル/エリア/間取り）" class="w-full px-4 py-2 border border-[var(--color-border)] bg-white">
                        <select id="admin-works-area" class="w-full md:w-40 px-4 py-2 border border-[var(--color-border)] bg-white"><option value="__all">エリア：すべて</option></select>
                        <select id="admin-works-layout" class="w-full md:w-40 px-4 py-2 border border-[var(--color-border)] bg-white"><option value="__all">間取り：すべて</option></select>
                        <button id="admin-works-clear" type="button" class="site-btn site-btn--md site-btn--outline-muted min-w-28">
                            <span class="site-btn__inner">クリア</span>
                        </button>
                    </div>
                </div>
                <div id="works-list" class="divide-y divide-[var(--color-border)]"><div class="text-center py-8 text-gray-500">読み込み中...</div></div>
                <div id="admin-works-pager" class="hidden mt-5 flex items-center justify-end gap-3 text-sm text-muted">
                    <button id="admin-works-prev" type="button" class="site-btn site-btn--compact site-btn--outline-muted"><span class="site-btn__inner">前へ</span></button>
                    <span id="admin-works-page-label" class="tabular-nums">1 / 1</span>
                    <button id="admin-works-next" type="button" class="site-btn site-btn--compact site-btn--outline-muted"><span class="site-btn__inner">次へ</span></button>
                </div>
            </div>
        </div>
        <!-- Masters Tab -->
        <div id="content-masters" class="tab-content hidden">
            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-white p-6">
                    <h2 class="font-serif text-xl text-ink mb-5">エリア</h2>
                    <div id="masters-areas-list" class="flex flex-wrap gap-2 mb-4 min-h-[2rem]"></div>
                    <div class="flex gap-2 mb-2">
                        <input id="masters-area-input" type="text" placeholder="例：大阪市" class="flex-1 px-4 py-2 border border-[var(--color-border)] bg-white">
                        <button type="button" onclick="addMasterValue('areas')" class="site-btn site-btn--md site-btn--primary"><span class="site-btn__inner">追加</span></button>
                    </div>
                    <div id="masters-areas-bulk-wrap" class="hidden mt-2">
                        <textarea id="masters-areas-bulk" rows="5" placeholder="1行1件で貼り付け" class="w-full px-3 py-2 text-sm border border-[var(--color-border)] bg-white mb-2"></textarea>
                        <button type="button" onclick="bulkAddMasterValues('areas')" class="site-btn site-btn--md site-btn--outline-ink w-full"><span class="site-btn__inner">一括追加</span></button>
                    </div>
                    <button type="button" onclick="toggleBulk('areas')" class="text-xs text-muted underline mt-1">まとめて追加</button>
                </div>
                <div class="bg-white p-6">
                    <h2 class="font-serif text-xl text-ink mb-5">間取り</h2>
                    <div id="masters-layouts-list" class="flex flex-wrap gap-2 mb-4 min-h-[2rem]"></div>
                    <div class="flex gap-2 mb-2">
                        <input id="masters-layout-input" type="text" placeholder="例：2LDK" class="flex-1 px-4 py-2 border border-[var(--color-border)] bg-white">
                        <button type="button" onclick="addMasterValue('layouts')" class="site-btn site-btn--md site-btn--primary"><span class="site-btn__inner">追加</span></button>
                    </div>
                    <div id="masters-layouts-bulk-wrap" class="hidden mt-2">
                        <textarea id="masters-layouts-bulk" rows="5" placeholder="1行1件で貼り付け" class="w-full px-3 py-2 text-sm border border-[var(--color-border)] bg-white mb-2"></textarea>
                        <button type="button" onclick="bulkAddMasterValues('layouts')" class="site-btn site-btn--md site-btn--outline-ink w-full"><span class="site-btn__inner">一括追加</span></button>
                    </div>
                    <button type="button" onclick="toggleBulk('layouts')" class="text-xs text-muted underline mt-1">まとめて追加</button>
                </div>
                <div class="bg-white p-6">
                    <h2 class="font-serif text-xl text-ink mb-5">ブログカテゴリ</h2>
                    <div id="masters-categories-list" class="flex flex-wrap gap-2 mb-4 min-h-[2rem]"></div>
                    <div class="flex gap-2 mb-2">
                        <input id="masters-category-input" type="text" placeholder="例：お知らせ" class="flex-1 px-4 py-2 border border-[var(--color-border)] bg-white">
                        <button type="button" onclick="addMasterValue('categories')" class="site-btn site-btn--md site-btn--primary"><span class="site-btn__inner">追加</span></button>
                    </div>
                    <div id="masters-categories-bulk-wrap" class="hidden mt-2">
                        <textarea id="masters-categories-bulk" rows="5" placeholder="1行1件で貼り付け" class="w-full px-3 py-2 text-sm border border-[var(--color-border)] bg-white mb-2"></textarea>
                        <button type="button" onclick="bulkAddMasterValues('categories')" class="site-btn site-btn--md site-btn--outline-ink w-full"><span class="site-btn__inner">一括追加</span></button>
                    </div>
                    <button type="button" onclick="toggleBulk('categories')" class="text-xs text-muted underline mt-1">まとめて追加</button>
                </div>
            </div>
        </div>
    </div>

    <!-- News Modal -->
    <div id="news-modal" class="fixed inset-0 bg-gray-900/55 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
        <div data-admin-modal-panel class="bg-white shadow-2xl max-w-4xl w-full max-h-[92vh] overflow-y-auto">
            <div class="p-6">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-serif text-2xl text-ink" id="news-modal-title">ブログを追加</h3>
                    <button onclick="closeNewsModal()" class="text-gray-400 hover:text-gray-600 cursor-pointer"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
                </div>
                <form id="news-form" class="space-y-4">
                    <input type="hidden" id="news-id">
                    <div><label class="block text-sm font-medium text-ink mb-2">タイトル *</label><input type="text" id="news-title" required class="w-full px-4 py-2"></div>
                    <div class="grid md:grid-cols-2 gap-4">
                        <div><label class="block text-sm font-medium text-ink mb-2">日付 *</label><input type="date" id="news-date" required class="w-full px-4 py-2"></div>
                        <div><label class="block text-sm font-medium text-ink mb-2">カテゴリー *</label><select id="news-category" required class="w-full px-4 py-2"><option value="">選択してください</option></select></div>
                    </div>
                    <div><label class="block text-sm font-medium text-ink mb-2">本文 *</label><textarea id="news-content" rows="6" required class="w-full px-4 py-2"></textarea></div>
                    <div>
                        <label class="block text-sm font-medium text-ink mb-2">画像</label>
                        <input type="file" id="news-image-file" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-orange-600">
                        <div id="news-image-preview" class="mt-2 hidden"><img id="news-image-preview-img" class="max-w-full h-48 object-cover"><p class="text-xs text-gray-500 mt-1">プレビュー</p></div>
                        <input type="hidden" id="news-image">
                    </div>
                    <div class="flex justify-end space-x-3 pt-4">
                        <button type="button" onclick="closeNewsModal()" class="site-btn site-btn--md site-btn--outline-muted">
                            <span class="site-btn__inner">キャンセル</span>
                        </button>
                        <button type="submit" class="site-btn site-btn--md site-btn--primary">
                            <span class="site-btn__inner">保存</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Work Modal -->
    <div id="work-modal" class="fixed inset-0 bg-gray-900/55 backdrop-blur-sm hidden items-center justify-center z-50 p-4">
        <div data-admin-modal-panel class="bg-white shadow-2xl max-w-4xl w-full max-h-[92vh] overflow-y-auto">
            <div class="p-6">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-serif text-2xl text-ink" id="work-modal-title">施工事例を追加</h3>
                    <button onclick="closeWorkModal()" class="text-gray-400 hover:text-gray-600 cursor-pointer"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
                </div>
                <form id="work-form" class="space-y-4">
                    <input type="hidden" id="work-id">
                    <div><label class="block text-sm font-medium text-ink mb-2">タイトル *</label><input type="text" id="work-title" required class="w-full px-4 py-2"></div>
                    <div class="grid md:grid-cols-2 gap-4">
                        <div><label class="block text-sm font-medium text-ink mb-2">エリア *</label><select id="work-area" required class="w-full px-4 py-2"><option value="">選択してください</option></select></div>
                        <div><label class="block text-sm font-medium text-ink mb-2">間取り *</label><select id="work-layout" required class="w-full px-4 py-2"><option value="">選択してください</option></select></div>
                    </div>
                    <div><label class="block text-sm font-medium text-ink mb-2">説明 *</label><textarea id="work-description" rows="4" required class="w-full px-4 py-2"></textarea></div>
                    <div>
                        <label class="block text-sm font-medium text-ink mb-2">メイン画像 *</label>
                        <input type="file" id="work-image-file" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-orange-600">
                        <div id="work-image-preview" class="mt-2 hidden"><img id="work-image-preview-img" class="max-w-full h-48 object-cover"><p class="text-xs text-gray-500 mt-1">プレビュー</p></div>
                        <input type="hidden" id="work-image">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">追加画像（複数可）</label>
                        <input type="file" id="work-images-file" accept="image/*" multiple class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-orange-600">
                        <div id="work-images-preview" class="mt-2 hidden grid grid-cols-3 gap-2"></div>
                        <input type="hidden" id="work-images">
                    </div>
                    <div class="flex justify-end space-x-3 pt-4">
                        <button type="button" onclick="closeWorkModal()" class="site-btn site-btn--md site-btn--outline-muted">
                            <span class="site-btn__inner">キャンセル</span>
                        </button>
                        <button type="submit" class="site-btn site-btn--md site-btn--primary">
                            <span class="site-btn__inner">保存</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
