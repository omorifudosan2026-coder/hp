              <p id="detail-layout" class="font-serif text-2xl text-ink"></p>
            </div>
            <div class="bg-white p-6 border border-[#DDD9D2]">
              <p class="font-mono-label text-xs text-muted mb-2 tracking-widest">AREA</p>
              <p id="detail-area-size" class="text-xl font-medium text-ink"></p>
            </div>
            <div class="bg-white p-6 border border-[#DDD9D2]">
              <p class="font-mono-label text-xs text-muted mb-2 tracking-widest">AGE</p>
              <p id="detail-age" class="text-xl font-medium text-ink"></p>
