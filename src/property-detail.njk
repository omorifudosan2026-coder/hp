<section class="pt-32 pb-24 bg-white min-h-screen">
  <div class="max-w-4xl mx-auto px-6 md:px-10">
    <div id="detail-loading" class="text-center py-20">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-[#DDD9D2] border-t-[#1A1A1A]"></div>
      <p class="text-muted text-sm mt-3">読み込み中...</p>
    </div>
    <div id="detail-error" class="hidden text-center py-20 max-w-xl mx-auto">
      <p class="text-ink text-base mb-6" id="detail-error-text"></p>
      <a href="/properties.html" class="inline-flex items-center gap-2 text-sm text-ink border-b border-ink pb-0.5 hover:text-[#E8621A] hover:border-[#E8621A] transition-colors">物件一覧へ戻る</a>
    </div>
    <article id="detail-content" class="hidden">
      <a href="/properties.html" class="text-xs text-muted hover:text-ink transition-colors mb-8 inline-flex items-center gap-2">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
        物件一覧
      </a>
      <div class="bg-white border border-[#DDD9D2] mt-6">
        <div id="detail-hero" class="relative h-72 md:h-96 bg-[#E2DDD2]"></div>
        <div class="p-8 md:p-12">
          <div id="detail-label-wrap" class="mb-4"></div>
