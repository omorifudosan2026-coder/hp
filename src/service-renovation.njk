firebase: true
---

<!-- Page Header -->
<section class="page-header page-header--split pt-20 pb-10 md:pt-24 md:pb-12" style="--page-header-photo: url('/images/services/service-renovation.webp');">
  <div class="page-header__grid">
    <div class="page-header__text">
      <p class="section-label mb-4">Service 02</p>
      <h1 class="font-serif text-ink">仲介＋リノベ</h1>
      <p class="page-header__lede">買う前から工務店目線で、<br>総額と完成形まで見える提案をします。</p>
    </div>
    <div class="page-header__photo" role="img" aria-label="仲介＋リノベの写真"></div>
  </div>
</section>

<!-- Worries & Reasons -->
<section class="buyback-reason-section bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="buyback-reason-lead" data-reveal>
      <h2 class="font-serif text-3xl md:text-4xl text-ink leading-tight">買う前に、完成形と総額まで見える。</h2>
      <p>物件選びとリノベ提案を同時に進めるから、<br class="hidden md:inline">「あとで想定外」を減らしながら判断できます。</p>
    </div>

    <div class="buyback-section-heading" data-reveal data-delay="60">
      <div class="buyback-section-heading__title">
        <span class="buyback-section-heading__line" aria-hidden="true"></span>
        <div class="buyback-section-heading__copy">
          <h2 class="font-serif text-xl md:text-2xl text-ink">こんなご相談に対応しています</h2>
          <p class="buyback-section-intro">中古購入＋リノベを検討中の方へ、物件・費用・完成後まで一体でサポートします。</p>
        </div>
        <span class="buyback-section-heading__line" aria-hidden="true"></span>
      </div>
    </div>

    <div class="buyback-reason-list" data-reveal data-delay="140">
      <article class="buyback-reason-item">
        <div class="buyback-reason-item__media">
          <img src="/images/worries/renovation-worry-01.webp" alt="中古物件を確認する様子" width="960" height="720" loading="lazy" decoding="async">
        </div>
        <div class="buyback-reason-item__body">
          <div class="buyback-reason-item__worry">
            <div class="buyback-reason-item__header">
              <p class="buyback-reason-item__num">01</p>
              <h3 class="font-serif text-lg text-ink">中古物件は不安</h3>
            </div>
            <p>見た目だけでは分からない構造や配管の状態が心配。買ってから問題が出るのが怖い。</p>
          </div>
          <p class="buyback-reason-item__bridge">大森不動産なら</p>
          <div class="buyback-reason-item__solution">
            <h4 class="font-serif text-ink">工務店目線で、買う前にリスクを診断できる</h4>
            <p>間取り変更の可否・構造壁・配管・雨漏りリスクまで事前に確認。購入後に発覚しやすい問題を先に把握し、判断しやすい状態をつくります。</p>
          </div>
        </div>
      </article>

      <article class="buyback-reason-item buyback-reason-item--reverse">
        <div class="buyback-reason-item__media">
          <img src="/images/worries/renovation-worry-02.webp" alt="費用計画を相談する様子" width="960" height="720" loading="lazy" decoding="async">
        </div>
        <div class="buyback-reason-item__body">
          <div class="buyback-reason-item__worry">
            <div class="buyback-reason-item__header">
              <p class="buyback-reason-item__num">02</p>
              <h3 class="font-serif text-lg text-ink">リフォーム費がわからない</h3>
            </div>
            <p>物件価格だけでは総額が見えず、資金計画を立てにくい。</p>
          </div>
          <p class="buyback-reason-item__bridge">大森不動産なら</p>
          <div class="buyback-reason-item__solution">
            <h4 class="font-serif text-ink">物件＋工事＋諸費用を一体で見積もれる</h4>
            <p>物件選定と同時にリノベ費用を積み上げるため、「結局いくらかかるか」を早い段階で把握できます。予算オーバーのリスクを抑えて検討できます。</p>
          </div>
        </div>
      </article>

      <article class="buyback-reason-item">
        <div class="buyback-reason-item__media">
          <img src="/images/worries/renovation-worry-03.webp" alt="間取りプランを確認する様子" width="960" height="720" loading="lazy" decoding="async">
        </div>
        <div class="buyback-reason-item__body">
          <div class="buyback-reason-item__worry">
            <div class="buyback-reason-item__header">
              <p class="buyback-reason-item__num">03</p>
              <h3 class="font-serif text-lg text-ink">買ってから後悔したくない</h3>
            </div>
            <p>「完成後の暮らし」が見えないまま決めるのが不安。</p>
          </div>
          <p class="buyback-reason-item__bridge">大森不動産なら</p>
          <div class="buyback-reason-item__solution">
            <h4 class="font-serif text-ink">購入前に、完成後のイメージまで提案できる</h4>
            <p>間取り・水回り・動線まで含めたプランを先に共有。暮らしのイメージを持ったうえで購入を決められるので、後悔の少ない選択につながります。</p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

