<!-- Page Header -->
<section class="page-header page-header--split pt-20 pb-10 md:pt-24 md:pb-12">
  <div class="page-header__grid">
    <div class="page-header__text">
      <p class="section-label mb-4">Works</p>
      <h1 class="font-serif text-ink">施工事例</h1>
      <p class="page-header__lede">大森不動産がお手伝いした、<br>リノベーション事例をご紹介します。</p>
    </div>
    <div class="page-header__photo" role="img" aria-label="施工事例の写真"></div>
  </div>
</section>

<!-- Works Grid -->
<section class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div id="loading" class="text-center py-16">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-[#DDD9D2] border-t-[#1A1A1A]"></div>
      <p class="text-muted text-sm mt-3">読み込み中...</p>
    </div>
    <div class="mb-8 flex flex-col sm:flex-row gap-3">
      <select id="works-filter-area" class="px-4 py-2 border border-[#DDD9D2] bg-white text-sm text-ink w-full sm:w-44">
        <option value="">エリア：すべて</option>
      </select>
      <select id="works-filter-layout" class="px-4 py-2 border border-[#DDD9D2] bg-white text-sm text-ink w-full sm:w-44">
        <option value="">間取り：すべて</option>
      </select>
    </div>
    <div id="works-grid" class="works-pickup-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12 lg:gap-14"></div>
    <div id="works-pagination" class="pt-12 flex justify-center"></div>
    <div id="no-works" class="hidden text-center py-20">
      <p class="text-muted text-sm">現在、施工事例はありません</p>
    </div>
  </div>
</section>

