---
layout: admin.njk
permalink: /login.html
title: ログイン | 大森不動産 管理画面
bodyClass: bg-cream min-h-screen flex items-center justify-center px-6 py-10
---

    <div class="max-w-md w-full">
        <div class="text-center mb-8">
            <p class="section-label justify-center mb-5">Admin Login</p>
            <h1 class="font-serif text-3xl text-ink">
                <span class="text-primary">大森</span>不動産
            </h1>
            <p class="mt-3 text-sm text-muted">管理画面にログイン</p>
        </div>

        <!-- Login Form -->
        <div class="bg-white border border-[var(--color-border)] shadow-[0_12px_40px_rgba(26,26,26,0.06)] p-8">
            <form id="login-form" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-ink mb-2">メールアドレス</label>
                    <input type="email" id="email" required
                        class="w-full px-4 py-3 transition"
                        placeholder="admin@example.com">
                </div>
                <div>
                    <label class="block text-sm font-medium text-ink mb-2">パスワード</label>
                    <input type="password" id="password" required
                        class="w-full px-4 py-3 transition"
                        placeholder="••••••••">
                </div>
                <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 text-sm">
                    <p class="font-medium">ログインに失敗しました</p>
                    <p id="error-text"></p>
                </div>
                <button type="submit" id="login-btn" class="site-btn site-btn--lg site-btn--primary w-full disabled:opacity-60 disabled:cursor-not-allowed">
                    <span class="site-btn__inner">ログイン</span>
                </button>
                <div id="loading" class="hidden text-center">
                    <div class="inline-block animate-spin h-8 w-8 border-b-2 border-primary"></div>
                    <p class="text-gray-600 mt-2">ログイン中...</p>
                </div>
            </form>
            <div class="mt-7 pt-6 border-t border-[var(--color-border)]">
                <p class="text-xs sm:text-sm text-muted text-center whitespace-nowrap">ログイン情報を忘れた場合は、管理者にお問い合わせください</p>
            </div>
        </div>

        <div class="text-center mt-6">
            <a href="/index.html" class="section-viewall-link inline-flex items-center gap-2 text-sm text-muted border-b border-[#DDD9D2] pb-0.5 hover:text-ink">
                ← 公開サイトに戻る
            </a>
        </div>
    </div>

    <script>
        const loginForm = document.getElementById('login-form');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const loginBtn = document.getElementById('login-btn');
        const loadingEl = document.getElementById('loading');
        const errorMessage = document.getElementById('error-message');
        const errorText = document.getElementById('error-text');

        auth.onAuthStateChanged((user) => {
            if (user) {
                window.location.href = '/admin-firebase.html';
            }
        });

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = emailInput.value;
            const password = passwordInput.value;

            loginBtn.disabled = true;
            loginBtn.classList.add('hidden');
            loadingEl.classList.remove('hidden');
            errorMessage.classList.add('hidden');

            try {
                await auth.signInWithEmailAndPassword(email, password);
                window.location.href = '/admin-firebase.html';
            } catch (error) {
                console.error('Login error:', error);
                let errorMsg = 'ログインに失敗しました。';
                switch (error.code) {
                    case 'auth/invalid-email':      errorMsg = 'メールアドレスの形式が正しくありません。'; break;
                    case 'auth/user-disabled':      errorMsg = 'このアカウントは無効化されています。'; break;
                    case 'auth/user-not-found':     errorMsg = 'メールアドレスまたはパスワードが間違っています。'; break;
                    case 'auth/wrong-password':     errorMsg = 'メールアドレスまたはパスワードが間違っています。'; break;
                    case 'auth/too-many-requests':  errorMsg = 'ログイン試行回数が多すぎます。しばらく待ってから再度お試しください。'; break;
                    default: errorMsg = `エラー: ${error.message}`;
                }
                errorText.textContent = errorMsg;
                errorMessage.classList.remove('hidden');
                loginBtn.disabled = false;
                loginBtn.classList.remove('hidden');
                loadingEl.classList.add('hidden');
            }
        });
    </script>
