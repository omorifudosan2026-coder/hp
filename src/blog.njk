---
layout: base.njk
permalink: /blog.html
title: ブログ
activePage: blog
firebase: true
pageScript: js/news-firebase.js
---

<!-- Page Header -->
<section class="page-header page-header--split pt-20 pb-10 md:pt-24 md:pb-12" style="--page-header-photo: url('/images/backgrounds/blog-hero.webp'); --page-header-photo-position: center 75%;">
  <div class="page-header__grid">
    <div class="page-header__text">
      <p class="section-label mb-4">Blog</p>
      <h1 class="font-serif text-ink">ブログ</h1>
      <p class="page-header__lede">不動産購入の不安に答える、<br>記事を発信しています。</p>
    </div>
    <div class="page-header__photo" role="img" aria-label="ブログの写真"></div>
  </div>
</section>

<!-- Blog List -->
<section class="content-list-section py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <!-- Category filter（スマホ：プルダウン / PC：タブ） -->
    <select id="news-tabs-select" class="news-tabs-select mb-8 w-full md:hidden px-4 py-2 border border-[#DDD9D2] bg-white text-sm text-ink" aria-label="カテゴリで絞り込む"></select>
    <div id="news-tabs" class="mb-8 hidden md:flex flex-wrap items-center gap-2"></div>
    <div id="loading" class="text-center py-16">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-[#DDD9D2] border-t-[#1A1A1A]"></div>
      <p class="text-muted text-sm mt-3">読み込み中...</p>
    </div>
    <div id="news-list" class="works-pickup-grid grid sm:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12 lg:gap-14"></div>
    <div id="news-pagination" class="pt-12 flex justify-center"></div>
    <div id="no-news" class="hidden text-center py-16">
      <p class="text-muted text-sm">現在、記事はありません</p>
    </div>
  </div>
</section>

{% include "partials/cta-section.njk" %}
