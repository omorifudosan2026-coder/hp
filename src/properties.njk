---
layout: base.njk
permalink: /properties.html
title: 物件一覧
activePage: properties
firebase: true
pageScript: js/properties-firebase.js
---

    <!-- Page Header -->
    <section class="pt-32 pb-16 bg-cream">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <p class="section-label mb-6">Properties</p>
        <h1 class="font-serif text-5xl md:text-6xl text-ink">物件一覧</h1>
        <p class="text-muted text-base mt-4">リノベーション可能な魅力的な物件をご紹介します</p>
      </div>
    </section>

    <!-- Search & Filter Section -->
    <section class="py-12 bg-white">
        <div class="container mx-auto px-6 md:px-12">
            <div class="max-w-6xl mx-auto">
                <div class="grid md:grid-cols-[1fr_1fr_1fr_auto] gap-4 md:gap-6 items-end">
                        <div>
                            <label class="block text-xs font-semibold text-gray-700 mb-2">エリア</label>
                            <select id="filter-area" class="w-full h-11 px-0 py-0 border-0 border-b border-[#DDD9D2] text-sm focus:ring-0 focus:border-ink transition bg-transparent">
                                <option>すべて</option><option>東京都</option><option>神奈川県</option><option>埼玉県</option><option>千葉県</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-700 mb-2">価格帯</label>
                            <select id="filter-price" class="w-full h-11 px-0 py-0 border-0 border-b border-[#DDD9D2] text-sm focus:ring-0 focus:border-ink transition bg-transparent">
                                <option>すべて</option><option>〜2,000万円</option><option>2,000〜3,000万円</option><option>3,000〜4,000万円</option><option>4,000万円〜</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-700 mb-2">間取り</label>
                            <select id="filter-layout" class="w-full h-11 px-0 py-0 border-0 border-b border-[#DDD9D2] text-sm focus:ring-0 focus:border-ink transition bg-transparent">
                                <option>すべて</option><option>1R・1K</option><option>1DK・1LDK</option><option>2DK・2LDK</option><option>3LDK以上</option>
                            </select>
                        </div>
                        <div class="flex">
                            <button type="button" id="filter-search-btn" class="site-btn site-btn--field site-btn--outline-ink inline-flex w-full justify-center md:w-auto">
                              <span class="site-btn__inner">絞り込み<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L14 13.414V19a1 1 0 01-1.447.894l-2-1A1 1 0 0110 18v-4.586L3.293 6.707A1 1 0 013 6V4z"/></svg></span>
                            </button>
                        </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Properties Grid -->
    <section class="py-20 bg-white">
        <div class="container mx-auto px-6 md:px-12">
            <div class="max-w-6xl mx-auto">
                <div class="mb-8">
                    <p class="text-sm text-gray-600 font-light">全 <span class="font-bold text-gray-900 text-lg" id="property-count">0</span> 件の物件があります</p>
                </div>
                <div id="properties-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
                <div id="no-properties" class="hidden text-center py-20">
                    <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 rounded-full flex items-center justify-center">
                        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                    </div>
                    <p class="text-gray-900 font-medium mb-1">現在、掲載中の物件はありません</p>
                    <p class="text-gray-500 text-sm font-light">新着物件は随時更新しています</p>
                </div>
                <div id="loading" class="text-center py-20">
                    <div class="inline-block animate-spin rounded-full h-10 w-10 border-2 border-gray-200 border-t-gray-900"></div>
                    <p class="text-gray-500 text-sm mt-4 font-light">読み込み中...</p>
                </div>
            </div>
        </div>
    </section>

    {% include "partials/cta-section.njk" %}
