<!-- Intersection Observer -->
<script>
(function(){
  var els = document.querySelectorAll('[data-reveal], [data-reveal-clip]');
  if (!els.length) return;
  els.forEach(function(el){
    if (el.hasAttribute('data-reveal-clip')) {
      el.classList.add('reveal-clip-ready');
    }
  });
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('is-revealed'); io.unobserve(e.target); }
    });
  }, { threshold: 0, rootMargin: '0px 0px -24px 0px' });
  els.forEach(function(el){ io.observe(el); });
})();
(function(){
  var hero = document.querySelector('.hero-intro');
  if (!hero) return;
  function activate(){
    hero.classList.add('hero-intro--active');
  }
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var heading = document.getElementById('hero-heading');
  if (!reduced && heading) {
    var counter = 0;
    function wrapTextNode(textNode) {
      var text = textNode.textContent;
      var parent = textNode.parentNode;
      if (!parent || !text) return;
      if (!/[^\s]/.test(text)) {
        textNode.textContent = '';
        return;
      }
      var frag = document.createDocumentFragment();
      Array.prototype.forEach.call(Array.from(text), function(ch) {
        if (ch === '\n' || ch === '\r') return;
        var span = document.createElement('span');
        span.className = 'hero-char';
        span.style.setProperty('--ci', String(counter));
        span.textContent = ch;
        frag.appendChild(span);
        counter += 1;
      });
      if (!frag.childNodes.length) {
        parent.removeChild(textNode);
        return;
      }
      parent.replaceChild(frag, textNode);
    }
    function walk(el) {
      var list = Array.prototype.slice.call(el.childNodes);
      list.forEach(function(child) {
        if (child.nodeType === 3) wrapTextNode(child);
        else if (child.nodeType === 1 && child.tagName !== 'BR') walk(child);
      });
    }
    walk(heading);
    if (counter > 0) hero.classList.add('hero-intro--chars-prepared');
  }
  if (reduced) {
    activate();
    return;
  }
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){
      activate();
    });
  });
})();
(function(){
  function setHeroCountFinals(root) {
    var scope = root || document;
    scope.querySelectorAll('[data-hero-count]').forEach(function(el) {
      var v = el.getAttribute('data-hero-count');
      if (v != null) el.textContent = v;
    });
  }
  function runHeroCountUp(root) {
    var scope = root || document;
    scope.querySelectorAll('[data-hero-count]').forEach(function(el) {
      var target = parseInt(el.getAttribute('data-hero-count'), 10);
      if (isNaN(target)) return;
      var start = performance.now();
      var dur = 1100;
      function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3);
      }
      function frame(now) {
        var t = Math.min(1, (now - start) / dur);
        el.textContent = String(Math.round(target * easeOutCubic(t)));
        if (t < 1) requestAnimationFrame(frame);
        else el.textContent = String(target);
      }
      requestAnimationFrame(frame);
    });
  }
  var roots = document.querySelectorAll('[data-hero-count-root]');
  if (!roots.length) return;
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (!e.isIntersecting) return;
      var root = e.target;
      io.unobserve(root);
      if (reduced) setHeroCountFinals(root);
      else runHeroCountUp(root);
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });
  roots.forEach(function(el){ io.observe(el); });
})();
</script>
