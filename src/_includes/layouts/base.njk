  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name | escape }}">
  <meta property="og:title" content="{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }} | リノベーションで叶える、あなたらしい暮らし{% endif %}">
  <meta property="og:description" content="{{ metaDesc | escape }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {% set ogImageFull = ogImage if ogImage else (site.url + '/images/hero-bg.jpg') %}
  <meta property="og:image" content="{{ ogImageFull }}">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="stylesheet" href="/css/main.css{% if mainCssCacheBust %}?v={{ mainCssCacheBust }}{% endif %}">
</head>
<body class="bg-cream" data-page="{{ activePage }}">

{% if firebase %}
