<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if noindex %}
    <meta name="robots" content="noindex, nofollow">
    {% endif %}
    <title>{% if title %}{{ title }} | 大森不動産{% else %}大森不動産 | リノベーションで叶える、あなたらしい暮らし{% endif %}</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-white">

{% if firebase %}
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-storage-compat.js"></script>
    <script src="/firebase-config.js"></script>
{% endif %}

    <!-- Header -->
    <header class="fixed top-4 left-0 right-0 z-50 px-4 md:px-6 transition-all duration-300" id="header" style="box-shadow: none !important;">
        <div class="max-w-7xl mx-auto">
            <div class="bg-white/90 backdrop-blur-lg rounded-full px-6 py-4" style="box-shadow: none !important;">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <a href="/index.html" class="flex items-center gap-3">
                            <img src="/images/logo.png" alt="大森不動産" class="h-10 w-auto">
                            <span class="text-lg font-bold text-navy tracking-tight hidden md:block">
                                大森<span class="text-orange">不動産</span>
                            </span>
                        </a>
                    </div>

                    <!-- Desktop Navigation -->
                    <nav class="hidden lg:flex items-center gap-2">
                        <a href="/concept.html" class="px-4 py-2 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'concept' else 'text-gray-700 hover:text-navy hover:bg-gray-50' }} rounded-full transition">サービス</a>
                        <a href="/properties.html" class="px-4 py-2 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'properties' else 'text-gray-700 hover:text-navy hover:bg-gray-50' }} rounded-full transition">物件一覧</a>
                        <a href="/works.html" class="px-4 py-2 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'works' else 'text-gray-700 hover:text-navy hover:bg-gray-50' }} rounded-full transition">施工事例</a>
                        <a href="/company.html" class="px-4 py-2 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'company' else 'text-gray-700 hover:text-navy hover:bg-gray-50' }} rounded-full transition">会社概要</a>
                        <a href="/news.html" class="px-4 py-2 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'news' else 'text-gray-700 hover:text-navy hover:bg-gray-50' }} rounded-full transition">お知らせ</a>
                        <a href="/contact.html" class="ml-2 inline-flex items-center gap-2 px-6 py-2.5 bg-orange text-white text-sm font-medium rounded-full hover:bg-orange-600 transition">
                            <span>お問い合わせ</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </a>
                    </nav>

                    <!-- Mobile Menu Button -->
                    <button id="mobile-menu-btn" class="lg:hidden p-2 hover:bg-gray-100 rounded-full transition">
                        <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="hidden lg:hidden mt-2">
            <div class="bg-white/95 backdrop-blur-lg rounded-3xl border border-gray-100/50 p-4 max-w-md mx-auto">
                <nav class="flex flex-col gap-1">
                    <a href="/concept.html" class="px-4 py-3 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'concept' else 'text-gray-700 hover:bg-gray-50' }} rounded-2xl transition">サービス</a>
                    <a href="/properties.html" class="px-4 py-3 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'properties' else 'text-gray-700 hover:bg-gray-50' }} rounded-2xl transition">物件一覧</a>
                    <a href="/works.html" class="px-4 py-3 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'works' else 'text-gray-700 hover:bg-gray-50' }} rounded-2xl transition">施工事例</a>
                    <a href="/company.html" class="px-4 py-3 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'company' else 'text-gray-700 hover:bg-gray-50' }} rounded-2xl transition">会社概要</a>
                    <a href="/news.html" class="px-4 py-3 text-sm font-medium {{ 'text-navy font-bold bg-gray-100' if activePage == 'news' else 'text-gray-700 hover:bg-gray-50' }} rounded-2xl transition">お知らせ</a>
                    <a href="/contact.html" class="mt-2 px-4 py-3 bg-orange text-white text-sm font-medium text-center rounded-2xl hover:bg-orange-600 transition">お問い合わせ</a>
                </nav>
            </div>
        </div>
    </header>

    <!-- Page Content -->
    {{ content | safe }}

    <!-- Footer -->
    <footer class="bg-gradient-to-br from-gray-900 via-navy to-gray-900 text-white py-20 relative overflow-hidden">
        <div class="absolute inset-0">
            <div class="absolute top-0 right-0 w-96 h-96 bg-orange/5 rounded-full -mr-48 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-80 h-80 bg-navy/30 rounded-full -ml-40 blur-3xl"></div>
        </div>

        <div class="container mx-auto px-6 md:px-12 relative z-10">
            <div class="grid md:grid-cols-4 gap-12 mb-12">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <img src="/images/logo.png" alt="大森不動産" class="h-10 w-auto">
                    </div>
                    <h3 class="text-2xl font-bold mb-4">
                        大森<span class="text-orange">不動産</span>
                    </h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-6">
                        物件探しからリノベーション、売買まで。ワンストップで叶える、理想の住まいづくり。
                    </p>
                    <div class="flex gap-3">
                        <a href="/contact.html" title="Facebook（準備中）" class="w-10 h-10 bg-white/5 hover:bg-orange rounded-full flex items-center justify-center transition-all duration-300 border border-white/10 hover:border-orange">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                        </a>
                        <a href="/contact.html" title="Instagram（準備中）" class="w-10 h-10 bg-white/5 hover:bg-orange rounded-full flex items-center justify-center transition-all duration-300 border border-white/10 hover:border-orange">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"/></svg>
                        </a>
                    </div>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-1 h-6 bg-orange rounded-full"></div>
                        <h4 class="font-bold text-lg">サービス</h4>
                    </div>
                    <ul class="space-y-3 text-sm">
                        <li><a href="/concept.html#property-renovation" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>物件購入+リノベーション</a></li>
                        <li><a href="/concept.html#resale" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>買取再販</a></li>
                        <li><a href="/concept.html#mediation" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>売買仲介・活用相談</a></li>
                    </ul>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-1 h-6 bg-orange rounded-full"></div>
                        <h4 class="font-bold text-lg">情報</h4>
                    </div>
                    <ul class="space-y-3 text-sm">
                        <li><a href="/properties.html" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>物件一覧</a></li>
                        <li><a href="/works.html" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>施工事例</a></li>
                        <li><a href="/news.html" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>お知らせ</a></li>
                        <li><a href="/company.html" class="text-gray-400 hover:text-orange transition-all duration-300 flex items-center gap-2 group"><svg class="w-4 h-4 text-orange opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>会社情報</a></li>
                    </ul>
                </div>
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-1 h-6 bg-orange rounded-full"></div>
                        <h4 class="font-bold text-lg">お問い合わせ</h4>
                    </div>
                    <div class="space-y-4 text-sm">
                        <a href="/contact.html" class="inline-flex items-center gap-2 px-5 py-3 bg-orange hover:bg-orange-600 text-white rounded-full transition-all duration-300 font-semibold shadow-lg shadow-orange/30">
                            お問い合わせフォーム
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5 text-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 mb-1">電話番号</p>
                                <p class="text-white font-semibold">0120-000-0000</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5 text-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 mb-1">営業時間</p>
                                <p class="text-white font-semibold">9:00-18:00</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="border-t border-white/10 pt-8">
                <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                    <p class="text-sm text-gray-400">&copy; 2026 大森不動産. All rights reserved.</p>
                    <div class="flex gap-6 text-xs text-gray-400">
                        <a href="/privacy.html" class="hover:text-orange transition">プライバシーポリシー</a>
                        <a href="/terms.html" class="hover:text-orange transition">利用規約</a>
                        <a href="/sitemap.html" class="hover:text-orange transition">サイトマップ</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/js/script.js"></script>
    <script src="/js/header.js"></script>
    {% if pageScript %}
    <script src="/{{ pageScript }}"></script>
    {% endif %}

</body>
</html>
