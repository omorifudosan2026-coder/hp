<!-- こんな方へ -->
<section class="pt-20 md:pt-28 {{ worryPb | default('pb-20 md:pb-28') }} {{ worryBg | default('bg-white') }}">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="mb-14 text-center" data-reveal>
      <p class="section-label mb-6">For You</p>
      <h2 class="font-serif text-3xl md:text-4xl text-ink">こんなお悩みはありませんか？</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal data-delay="100">
      {% for card in worryCards %}
      <div class="bg-white rounded-sm p-6 border border-[#DDD9D2]/70 flex flex-col">
        <div class="flex items-center justify-center mb-5 h-52">
          <img src="{{ card.image }}" alt="" class="w-full max-w-[240px] h-full object-contain" width="240" height="240" loading="lazy" decoding="async" aria-hidden="true">
        </div>
        <div class="flex items-center gap-3 mb-3">
          <span class="text-[#E8621A] font-serif text-lg shrink-0">{{ card.number }}</span>
          <h3 class="font-serif text-lg text-ink m-0">{{ card.title }}</h3>
        </div>
        <p class="text-sm text-muted leading-relaxed">{{ card.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
