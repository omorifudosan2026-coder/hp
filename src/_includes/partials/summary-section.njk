{% if summaryShowDivider | default(true) %}
<!-- V字ディバイダー: cream → white -->
<div class="bg-white">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 72" preserveAspectRatio="none" class="block w-full h-12 md:h-16 lg:h-[72px]" aria-hidden="true">
    <polygon points="0,0 1440,0 720,72" fill="#F7F4EF"/>
  </svg>
</div>
{% endif %}

<!-- まとめ -->
<section class="pt-16 md:pt-24 pb-16 md:pb-20 bg-white">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="text-center" data-reveal>
      <p class="section-label mb-8">{{ summaryLabel | default("Summary") }}</p>
      <h2 class="font-serif text-2xl md:text-3xl lg:text-4xl text-ink {% if summaryText %}mb-8{% endif %} leading-snug"><span class="reveal-underline">{{ summaryHeadline }}</span></h2>
      {% if summaryText %}
      <p class="text-muted text-lg md:text-xl leading-relaxed">{{ summaryText | safe }}</p>
      {% endif %}
    </div>
  </div>
</section>
