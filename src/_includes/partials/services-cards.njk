<div class="services-cards-grid {% if activePage == 'service-buyback' or activePage == 'service-renovation' or activePage == 'service-income' %}services-cards-grid--two md:grid-cols-2{% else %}services-cards-grid--three md:grid-cols-3{% endif %} grid gap-px bg-[#DDD9D2]">

  {% if activePage != "service-buyback" %}
  <a href="/service-buyback" class="solution-card-link bg-white px-5 py-6 md:p-10 flex h-full flex-col gap-4 md:gap-6" data-reveal data-delay="100" aria-label="買取再販サービスを詳しく見る">
    <div class="solution-card-link__head flex items-center gap-3 md:gap-4">
      <span class="solution-card-link__icon shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5V20a1 1 0 0 1-1 1h-5v-8H9v8H4a1 1 0 0 1-1-1z"/></svg>
      </span>
      <div>
        <p class="font-mono-label text-xs text-[#E8621A] mb-0.5">Service 01</p>
        <h3 class="font-serif text-lg md:text-xl text-ink">買取再販</h3>
      </div>
    </div>
    <p class="solution-card-desc text-sm text-muted leading-relaxed">状態を問わず、そのまま買い取り。</p>
  </a>
  {% endif %}

  {% if activePage != "service-renovation" %}
  <a href="/service-renovation" class="solution-card-link bg-white px-5 py-6 md:p-10 flex h-full flex-col gap-4 md:gap-6" data-reveal data-delay="200" aria-label="仲介＋リノベサービスを詳しく見る">
    <div class="solution-card-link__head flex items-center gap-3 md:gap-4">
      <span class="solution-card-link__icon shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </span>
      <div>
        <p class="font-mono-label text-xs text-[#E8621A] mb-0.5">Service 02</p>
        <h3 class="font-serif text-lg md:text-xl text-ink">仲介＋リノベ</h3>
      </div>
    </div>
    <p class="solution-card-desc text-sm text-muted leading-relaxed">買う前に、総額と完成形を把握。</p>
  </a>
  {% endif %}

  {% if activePage != "service-income" %}
  <a href="/service-income" class="solution-card-link bg-white px-5 py-6 md:p-10 flex h-full flex-col gap-4 md:gap-6" data-reveal data-delay="300" aria-label="収益不動産サービスを詳しく見る">
    <div class="solution-card-link__head flex items-center gap-3 md:gap-4">
      <span class="solution-card-link__icon shrink-0" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>
      </span>
      <div>
        <p class="font-mono-label text-xs text-[#E8621A] mb-0.5">Service 03</p>
        <h3 class="font-serif text-lg md:text-xl text-ink">収益不動産</h3>
      </div>
    </div>
    <p class="solution-card-desc text-sm text-muted leading-relaxed">修繕から出口まで、長期視点で。</p>
  </a>
  {% endif %}

</div>
