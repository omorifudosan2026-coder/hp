<!-- 施工事例ピックアップ -->
<section{% if worksId %} id="{{ worksId }}"{% endif %} class="works-pickup-section bg-white">
  <div class="works-pickup-section__shell {{ worksPy | default('pt-6 pb-9 md:py-28') }}" data-reveal>
    <div class="works-pickup-section__inner max-w-[1440px] mx-auto px-6 md:px-10">
      <div class="mb-12 text-center" data-reveal data-delay="200">
        <p class="section-label mb-4">Works</p>
        <h2 class="font-serif text-3xl md:text-4xl text-ink">{{ worksTitle | default('施工事例') }}</h2>
      </div>
      <div id="works-top-loading" class="text-center py-10" data-reveal data-delay="300">
        <div class="inline-block animate-spin rounded-full h-7 w-7 border-2 border-[#DDD9D2] border-t-[#1A1A1A]"></div>
      </div>
      <div id="works-top-grid" class="works-pickup-grid hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12 lg:gap-14" data-reveal data-delay="300"></div>
      <div class="mt-10 text-center" data-reveal data-delay="400">
        <a href="/works" class="site-btn site-btn--sm site-btn--outline-ink inline-flex">
          <span class="site-btn__inner">施工事例をすべて見る<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
    </div>
  </div>
</section>
<script src="/js/works-top.js"></script>
