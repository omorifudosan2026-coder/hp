<div class="services-showcase flex flex-col">

  <!-- Service 01: 買取再販（写真：左） -->
  <article class="services-showcase__row services-showcase__row--photo-left" data-reveal>
    <div class="services-showcase__body">
      <div class="services-showcase__media">
        <img src="/images/services/service-buyback.webp" alt="買取再販の施工イメージ" width="1280" height="720" loading="lazy" decoding="async" class="services-showcase__img">
      </div>
      <div class="services-showcase__content">
        <p class="services-subtitle services-showcase__label">Service 01</p>
        <h3 class="services-showcase__title font-serif text-2xl md:text-3xl text-ink leading-snug">買取再販</h3>
        <p class="services-showcase__desc text-sm md:text-base text-muted">古くて売れない、手間をかけたくない。<br class="md:hidden">そんな物件も状態を問わず買い取ります。</p>
        <a href="/service-buyback" class="site-btn site-btn--lg site-btn--outline-ink services-showcase__btn" aria-label="買取再販サービスを詳しく見る">
          <span class="site-btn__inner">詳しく見る<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
    </div>
  </article>

  <!-- Service 02: 仲介＋リノベ（写真：右） -->
  <article class="services-showcase__row services-showcase__row--photo-right" data-reveal data-delay="100">
    <div class="services-showcase__body">
      <div class="services-showcase__content">
        <p class="services-subtitle services-showcase__label">Service 02</p>
        <h3 class="services-showcase__title font-serif text-2xl md:text-3xl text-ink leading-snug">仲介＋リノベ</h3>
        <p class="services-showcase__desc text-sm md:text-base text-muted">中古物件を買いたい方向け。工務店目線で物件を判断し、買う前に総額と完成形を提示します。</p>
        <a href="/service-renovation" class="site-btn site-btn--lg site-btn--outline-ink services-showcase__btn" aria-label="仲介＋リノベサービスを詳しく見る">
          <span class="site-btn__inner">詳しく見る<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
      <div class="services-showcase__media">
        <img src="/images/services/service-renovation.webp" alt="仲介＋リノベの施工イメージ" width="1280" height="720" loading="lazy" decoding="async" class="services-showcase__img">
      </div>
    </div>
  </article>

  <!-- Service 03: 収益不動産（写真：左） -->
  <article class="services-showcase__row services-showcase__row--photo-left" data-reveal data-delay="200">
    <div class="services-showcase__body">
      <div class="services-showcase__media">
        <img src="/images/services/service-income.webp" alt="収益不動産の施工イメージ" width="1280" height="720" loading="lazy" decoding="async" class="services-showcase__img">
      </div>
      <div class="services-showcase__content">
        <p class="services-subtitle services-showcase__label">Service 03</p>
        <h3 class="services-showcase__title font-serif text-2xl md:text-3xl text-ink leading-snug">収益不動産</h3>
        <p class="services-showcase__desc text-sm md:text-base text-muted">オーナー・管理会社向け。修繕リスクを把握し、家賃アップの改修提案から出口まで設計します。</p>
        <a href="/service-income" class="site-btn site-btn--lg site-btn--outline-ink services-showcase__btn" aria-label="収益不動産サービスを詳しく見る">
          <span class="site-btn__inner">詳しく見る<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
    </div>
  </article>

</div>
