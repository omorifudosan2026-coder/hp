{# 全ページ共通CTA（トップの文言・構成を基準） #}
<section class="py-24 md:py-32 bg-cream" data-reveal>
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="max-w-5xl mx-auto text-center">
      <p class="section-label mb-8">Contact Us</p>
      <div class="mb-8 flex justify-center min-w-0 overflow-x-auto overflow-y-hidden pb-0.5 sm:overflow-visible [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl xl:text-5xl text-ink text-center whitespace-nowrap leading-snug shrink-0 px-1">
          理想の住まいを一緒に探しませんか？
        </h2>
      </div>
      <p class="text-muted text-sm md:text-base mb-12 leading-relaxed text-balance max-w-3xl mx-auto">
        物件探しからリノベーション、資金計画まで、経験豊富なスタッフが丁寧にサポートいたします
      </p>
      <div class="flex flex-wrap gap-4 mb-16 justify-center">
        <a href="/contact.html" class="site-btn site-btn--lg site-btn--primary inline-flex">
          <span class="site-btn__inner">無料相談する<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
        <a href="/properties.html" class="site-btn site-btn--lg site-btn--outline-ink inline-flex">
          <span class="site-btn__inner">物件を見る</span>
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-x-12 gap-y-6 pt-8 border-t border-[#DDD9D2]">
        <div class="text-center min-w-[10rem]">
          <p class="font-mono-label text-xs text-muted mb-2 tracking-widest">PHONE</p>
          <a href="tel:0120-000-0000" class="text-xl font-bold text-ink hover:text-[#E8621A] transition-colors">0120-000-0000</a>
        </div>
        <div class="text-center min-w-[10rem]">
          <p class="font-mono-label text-xs text-muted mb-2 tracking-widest">HOURS</p>
          <p class="text-base font-medium text-ink">9:00–18:00</p>
        </div>
      </div>
    </div>
  </div>
</section>
