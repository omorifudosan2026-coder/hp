<!-- 3つの理由 -->
<section class="py-20 md:py-28 {{ reasonsBg | default('bg-white') }}">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="mb-14" data-reveal>
      <p class="section-label mb-6">{{ reasonsLabel | default("Why We Can") }}</p>
      <h2 class="font-serif text-3xl md:text-4xl text-ink">{{ reasonsTitle }}</h2>
      {% if reasonsDescription %}
      <p class="text-muted text-sm md:text-base mt-4 leading-relaxed">{{ reasonsDescription }}</p>
      {% endif %}
    </div>
    <div class="flex flex-col border border-[#DDD9D2]" data-reveal data-delay="80">
      {% for reason in reasons %}
      <div class="grid md:grid-cols-[120px_1fr]{% if not loop.last %} border-b border-[#DDD9D2]{% endif %}">
        <div class="flex items-center justify-center {% if loop.index == 1 %}bg-[#E8621A]{% elif loop.index == 2 %}bg-ink{% else %}bg-[#5C5047]{% endif %} px-8 py-6 md:py-0">
          <span class="font-serif text-4xl font-bold text-white leading-none">{{ reason.number }}</span>
        </div>
        <div class="p-8 bg-white">
          <h3 class="font-serif text-xl text-ink mb-3">{{ reason.title }}</h3>
          <p class="text-sm text-muted leading-relaxed">{{ reason.description }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
