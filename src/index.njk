      </p>
    </div>

    <!-- 段差3カラム -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:items-start">

      <!-- POINT 01：一番高い -->
      <div class="md:mt-0 bg-white border border-[#DDD9D2] p-8 xl:p-10 flex flex-col gap-5" data-reveal>
        <div class="flex items-center justify-center h-72">
