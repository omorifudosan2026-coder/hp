---
layout: base.njk
permalink: /index.html
activePage: index
firebase: true
pageScript: js/news-top.js
---

<!-- Hero -->
<section class="hero-intro hero-intro--layout relative min-h-screen max-lg:flex max-lg:flex-col bg-white pt-[calc(var(--site-header-height)+1.25rem)] md:pt-[calc(var(--site-header-height)+1.5rem)] max-lg:pb-0 pb-10 lg:pt-0 lg:pb-0">
  <div class="hero-intro__left-col max-lg:contents lg:flex lg:flex-col lg:min-h-0 lg:items-center lg:justify-center lg:relative">
    <div class="hero-intro__title-wrap flex flex-col items-center text-center px-6 md:px-10 xl:px-12 max-lg:mb-6 lg:mb-0 lg:w-full lg:py-4 lg:px-0">
      <div class="hero-intro__head-block">
        <h1 id="hero-heading" class="hero-intro__title font-serif text-ink">工務店がいる、不動産会社。</h1>
        <p class="hero-intro__lede text-muted" data-hero-piece data-hero-delay="160">物件を買う前から、建物の未来まで見て提案する。<br>それが大森不動産です。</p>
        <p class="hero-intro__stats-inline" data-hero-piece data-hero-delay="220">
          <span class="hero-intro__stat-inline">
            <span class="hero-intro__stat-inline-value">
              <span data-hero-count-root><span data-hero-count="200">0</span><span class="hero-intro__stat-inline-accent">+</span></span>
            </span>
            <span class="hero-intro__stat-inline-label">年間施工</span>
          </span>
          <span class="hero-intro__stat-inline-sep" aria-hidden="true"></span>
          <span class="hero-intro__stat-inline">
            <span class="hero-intro__stat-inline-value"><span class="hero-intro__stat-inline-accent">★</span>4.7</span>
            <span class="hero-intro__stat-inline-label">Google</span>
          </span>
        </p>
      </div>
    </div>
  </div>
  <div class="hero-intro__media-col w-full lg:min-h-0 flex flex-col max-lg:mt-8 lg:pr-0">
    <div class="hero-intro__visual-frame flex flex-1 min-h-0 flex-col pt-0 pb-0">
      <div class="hero-intro__visual relative flex-1 min-h-0 w-full overflow-hidden">
        <div class="hero-intro__visual-inner absolute inset-0 overflow-hidden">
          <img src="/images/backgrounds/hero-bg.jpg" alt="大森不動産の施工事例" width="1536" height="1024" fetchpriority="high" decoding="sync" sizes="100vw" class="hero-intro__img absolute inset-0 w-full h-full object-cover">
          <div class="hero-intro__visual-fade pointer-events-none absolute inset-0 z-[1]" aria-hidden="true"></div>
          <div class="absolute inset-0 z-[2] bg-ink/5 pointer-events-none" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Story / Philosophy -->
<section class="bg-white overflow-hidden">

  <!-- Mobile -->
  <div class="story-mobile-block lg:hidden py-20 md:py-28 px-6 md:px-10">
    <div class="story-mobile-hero -mx-6 md:-mx-10 mb-8 overflow-hidden aspect-[3/1] max-h-[7rem]" data-reveal>
      <img src="/images/backgrounds/ideal-home-cta-bg.webp" alt="家族が集まるダイニングと庭" class="w-full h-full object-cover object-[left_68%]" width="1672" height="941" loading="lazy" decoding="async">
    </div>
    <div class="mb-10 text-center" data-reveal data-delay="80">
      <p class="section-label mb-4">Our Story</p>
      <h2 class="font-serif text-2xl text-ink leading-tight text-balance">買って終わりじゃない、不動産。</h2>
      <span class="mt-4 mx-auto block h-px w-10 bg-[#E8621A]" aria-hidden="true"></span>
      <p class="mt-5 text-base leading-relaxed text-muted">不動産の失敗は、買った後に起きます。<br>工務店と一体で、物件探しから売却まで責任を持って関わります。</p>
      <div class="mt-7">
        <a href="/story" class="site-btn site-btn--md site-btn--outline-ink">
          <span class="site-btn__inner">私たちの想い<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
      </div>
    </div>
    <div class="story-mobile-collage flex gap-2 min-h-0" data-reveal data-delay="160">
      <div class="story-mobile-collage__cell flex-1 min-w-0 min-h-0 overflow-hidden bg-cream">
        <img src="/images/story/story-interior.webp" alt="リビング内観" class="w-full h-full object-cover" width="400" height="300" loading="lazy" decoding="async">
      </div>
      <div class="story-mobile-collage__cell flex-1 min-w-0 min-h-0 overflow-hidden bg-cream">
        <img src="/images/story/story-exterior.webp" alt="戸建て外観" class="w-full h-full object-cover" width="400" height="300" loading="lazy" decoding="async">
      </div>
    </div>

  </div>

  <!-- Desktop: 左縦長 / 中央テキスト / 右2枚 -->
  <div class="hidden lg:block lg:py-16 xl:py-20 lg:px-10 xl:px-14">
    <div class="story-desktop-layout lg:h-[620px] xl:h-[680px]">
      <!-- Left: tall vertical photo -->
      <div class="story-desktop-layout__photo min-w-0 overflow-hidden" data-reveal>
        <img src="/images/backgrounds/ideal-home-cta-bg.webp" alt="家族が集まるダイニングと庭" class="w-full h-full object-cover object-[left_68%]" width="1672" height="941" loading="lazy" decoding="async">
      </div>

      <!-- Center: text -->
      <div class="story-desktop-layout__text min-w-0 flex flex-col justify-center items-center text-center px-2 xl:px-4" data-reveal data-delay="100">
        <p class="section-label mb-5">Our Story</p>
        <h2 class="font-serif text-3xl xl:text-4xl text-ink leading-tight text-balance">買って終わりじゃない、<br>不動産。</h2>
        <span class="mt-4 mx-auto block h-px w-10 bg-[#E8621A]" aria-hidden="true"></span>
        <p class="mt-5 w-full text-base leading-relaxed text-muted">不動産の失敗は、買った後に起きます。<br>大森不動産は、工務店と一体になり、物件探しの段階から<br>リフォーム・将来の売却まで責任を持って関わります。<br><br>買ってから後悔する人を、一人でも減らすために。</p>
        <div class="mt-7">
          <a href="/story" class="site-btn site-btn--md site-btn--outline-ink">
            <span class="site-btn__inner">私たちの想い<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
          </a>
        </div>
      </div>

      <!-- Right: 2 stacked photos -->
      <div class="story-desktop-layout__stack min-w-0 flex flex-col gap-3 xl:gap-4">
        <div class="flex-1 min-h-0 overflow-hidden" data-reveal data-delay="200">
          <img src="/images/story/story-interior.webp" alt="リビング内観" class="w-full h-full object-cover" width="400" height="400" loading="lazy" decoding="async">
        </div>
        <div class="flex-1 min-h-0 overflow-hidden" data-reveal data-delay="300">
          <img src="/images/story/story-exterior.webp" alt="戸建て外観" class="w-full h-full object-cover" width="400" height="400" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </div>




</section>

<!-- Why Omori：2×2グリッド -->
<section class="index-advantage-section bg-white pt-2 pb-9 md:pt-10 md:pb-16" aria-label="大森不動産の強み">
  <div class="max-w-7xl mx-auto px-6 md:px-10">

    <!-- ヘッダー -->
    <div class="text-center mb-14 md:mb-16" data-reveal>
      <p class="section-label mb-4">OUR ADVANTAGE</p>
      <h2 class="font-serif text-3xl md:text-4xl text-ink leading-tight">選ばれる理由</h2>
      <span class="mt-5 mx-auto block h-px w-10 bg-[#E8621A]" aria-hidden="true"></span>
      <p class="mt-5 text-base leading-relaxed text-muted">
        工務店と一体の窓口で、購入前から総額感と工事の現実性まで一度に詰められます。
      </p>
    </div>

    <!-- 2×2グリッド -->
    <div class="advantage-grid grid grid-cols-1 md:grid-cols-2" data-reveal>

      <div class="advantage-grid__item flex items-start gap-5 md:gap-6">
        <div class="advantage-grid__icon shrink-0">
          <img src="/images/advantage/advantage-point-01.webp" alt="" width="400" height="400" loading="lazy" decoding="async" aria-hidden="true" class="w-full h-full object-contain">
        </div>
        <div class="advantage-grid__body min-w-0">
          <div class="advantage-grid__head">
            <span class="advantage-grid__num" aria-hidden="true">01</span>
            <h3 class="font-serif text-lg md:text-xl text-ink leading-snug mb-2 md:mb-3">失敗物件を避けられる</h3>
          </div>
          <p class="text-sm md:text-base leading-relaxed text-muted">建物のプロが物件をチェックするから、見えないリスクや将来のコストまで事前に見極められます。</p>
        </div>
      </div>

      <div class="advantage-grid__item flex items-start gap-5 md:gap-6">
        <div class="advantage-grid__icon advantage-grid__icon--sm shrink-0">
          <img src="/images/advantage/advantage-point-02.webp" alt="" width="400" height="400" loading="lazy" decoding="async" aria-hidden="true" class="w-full h-full object-contain">
        </div>
        <div class="advantage-grid__body min-w-0">
          <div class="advantage-grid__head">
            <span class="advantage-grid__num" aria-hidden="true">02</span>
            <h3 class="font-serif text-lg md:text-xl text-ink leading-snug mb-2 md:mb-3">総額で判断できる</h3>
          </div>
          <p class="text-sm md:text-base leading-relaxed text-muted">購入費用だけでなく、リノベーション費用や諸費用まで含めた総額で判断できるので、予算オーバーの不安を減らせます。</p>
        </div>
      </div>

      <div class="advantage-grid__item flex items-start gap-5 md:gap-6">
        <div class="advantage-grid__icon shrink-0">
          <img src="/images/advantage/advantage-point-03.webp" alt="" width="400" height="400" loading="lazy" decoding="async" aria-hidden="true" class="w-full h-full object-contain">
        </div>
        <div class="advantage-grid__body min-w-0">
          <div class="advantage-grid__head">
            <span class="advantage-grid__num" aria-hidden="true">03</span>
            <h3 class="font-serif text-lg md:text-xl text-ink leading-snug mb-2 md:mb-3">工事の現実性が分かる</h3>
          </div>
          <p class="text-sm md:text-base leading-relaxed text-muted">希望の暮らしがその物件で実現できるか、設計・施工のプロが事前に検証し、的確にアドバイスします。</p>
        </div>
      </div>

      <div class="advantage-grid__item flex items-start gap-5 md:gap-6">
        <div class="advantage-grid__icon advantage-grid__icon--sm shrink-0">
          <img src="/images/advantage/advantage-point-04.webp" alt="" width="400" height="400" loading="lazy" decoding="async" aria-hidden="true" class="w-full h-full object-contain">
        </div>
        <div class="advantage-grid__body min-w-0">
          <div class="advantage-grid__head">
            <span class="advantage-grid__num" aria-hidden="true">04</span>
            <h3 class="font-serif text-lg md:text-xl text-ink leading-snug mb-2 md:mb-3">資産価値を上げる提案ができる</h3>
          </div>
          <p class="text-sm md:text-base leading-relaxed text-muted">将来の売却や賃貸まで見据えた資産価値向上の提案で、長く安心できる住まいを実現します。</p>
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="mt-12 md:mt-14 flex justify-center" data-reveal>
      <a href="/concept" class="site-btn site-btn--md site-btn--outline-ink">
        <span class="site-btn__inner">選ばれる理由を詳しく見る<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
      </a>
    </div>

  </div>
</section>

<!-- Solutions: 3サービス -->
<section class="py-8 md:py-16 bg-cream index-solution" data-reveal>
  {% set servicesShowcaseLabel = "Services" %}
  {% set servicesShowcaseTitle = "状況に合わせた、3つのサービス" %}
  {% include "partials/services-showcase.njk" %}
</section>

{% set worksId = "works" %}
{% set worksLimit = 4 %}
{% include "partials/works-pickup.njk" %}

<!-- Blog / News preview -->
<section class="pt-16 pb-28 md:py-24 bg-cream" data-reveal>
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="mb-12 text-center">
      <p class="section-label mb-4">Blog</p>
      <h2 class="font-serif text-3xl md:text-4xl text-ink">お役立ち情報</h2>
      <p class="text-muted text-sm md:text-base mt-6 mx-auto max-w-2xl leading-relaxed">購入前の疑問に答える記事を更新しています。</p>
    </div>
    <div class="news-top-panel mx-auto w-full max-w-5xl">
      <div id="news-top-loading" class="py-6 text-center">
        <div class="inline-block animate-spin rounded-full h-5 w-5 border-2 border-[#DDD9D2] border-t-[#1A1A1A]"></div>
      </div>
      <div id="news-top-list" class="hidden"></div>
    </div>
    <div class="mt-10 flex justify-center">
      <a href="/blog" class="site-btn site-btn--lg site-btn--outline-ink">
        <span class="site-btn__inner">すべての記事を見る <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
      </a>
    </div>
  </div>
</section>

{% include "partials/cta-section.njk" %}
