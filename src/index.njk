    <div class="story-mobile-collage flex gap-2 min-h-0" data-reveal data-delay="160">
      <div class="story-mobile-collage__main flex-[3] min-w-0 overflow-hidden bg-cream">
        <img src="/images/story/story-interior.webp" alt="リビング内観" class="w-full h-full object-cover" width="600" height="900" loading="lazy" decoding="async">
      </div>
      <div class="story-mobile-collage__side flex flex-[2] min-w-0 flex-col gap-2">
        <div class="story-mobile-collage__cell flex-1 min-h-0 overflow-hidden bg-cream">
