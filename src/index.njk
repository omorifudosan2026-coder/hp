<!-- Hero -->
<section class="hero-intro hero-intro--layout relative min-h-screen max-lg:flex max-lg:flex-col bg-cream pt-[calc(var(--site-header-height)+1.25rem)] md:pt-[calc(var(--site-header-height)+1.5rem)] max-lg:pb-0 pb-10 lg:pt-0 lg:pb-0">
  <div class="hero-intro__left-col max-lg:contents lg:flex lg:flex-col lg:min-h-0 lg:items-center lg:justify-center lg:bg-dots lg:relative">
    <div class="hero-intro__title-wrap flex flex-col items-center text-center gap-7 px-6 md:px-10 xl:px-12 max-lg:max-w-xl max-lg:mb-6 lg:mb-0 lg:w-full lg:max-w-xl lg:gap-8 lg:py-4 lg:px-0">
      <h1 id="hero-heading" class="hero-intro__title font-serif text-ink">
        <span class="hero-intro__title-row hero-intro__title-row--lede"><span class="hero-intro__lede-line hero-intro__lede-line--first">工務店がいる</span></span>
        <em class="hero-intro__title-row hero-intro__title-accent not-italic" style="color:#E8621A">不動産会社。</em>
      </h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-md" data-hero-piece data-hero-delay="180">物件を買う前から、建物の未来まで見て提案する。<br>それが大森不動産です。</p>
      <!-- Stats badges -->
      <div class="flex items-center gap-5 md:gap-6" data-hero-piece data-hero-delay="220">
        <div class="flex flex-col items-center">
          <p class="font-serif text-xl md:text-3xl text-ink font-bold tabular-nums">
            <span data-hero-count-root><span data-hero-count="200">0</span><span class="text-lg md:text-xl text-[#E8621A]">+</span></span>
          </p>
          <p class="text-xs text-muted mt-0.5 tracking-wide">年間施工実績</p>
        </div>
        <span class="w-px h-8 bg-[#DDD9D2]" aria-hidden="true"></span>
        <div class="flex flex-col items-center">
          <p class="font-serif text-xl md:text-3xl text-ink font-bold"><span class="text-[#E8621A]">★</span><span class="tabular-nums">4.7</span></p>
          <p class="text-xs text-muted mt-0.5 tracking-wide">Google口コミ</p>
        </div>
      </div>
      <a href="/concept" class="site-btn site-btn--md site-btn--outline-ink shrink-0 self-center" data-hero-piece data-hero-delay="280">
        <span class="site-btn__inner">選ばれる理由<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
      </a>
    </div>
    <a href="#works" class="hero-scroll-hint hidden lg:flex" data-hero-piece data-hero-delay="520" aria-label="次のセクションへスクロール">
      <span class="hero-scroll-hint__label font-mono-label">Scroll</span>
      <span class="hero-scroll-hint__rail" aria-hidden="true">
        <span class="hero-scroll-hint__rail-line"></span>
        <span class="hero-scroll-hint__rail-dot"></span>
      </span>
    </a>
  </div>
  <div class="hero-intro__media-col w-full lg:min-h-0 flex flex-col max-lg:mt-8 lg:pr-0 lg:relative">
    <div class="hero-intro__visual-frame hidden lg:flex flex-1 min-h-0 flex-col pt-0 pb-0">
      <div class="hero-intro__visual relative flex-1 min-h-0 w-full overflow-hidden">
        <div class="hero-intro__visual-inner absolute inset-0 overflow-hidden">
          <img src="/images/backgrounds/hero-bg.jpg" alt="大森不動産の施工事例" width="1536" height="1024" fetchpriority="high" decoding="sync" sizes="100vw" class="hero-intro__img absolute inset-0 w-full h-full object-cover">
          <div class="hero-intro__visual-fade pointer-events-none absolute inset-0 z-[1]" aria-hidden="true"></div>
          <div class="absolute inset-0 z-[2] bg-ink/5 pointer-events-none" aria-hidden="true"></div>
        </div>
      </div>
    </div>
    <p class="section-label hero-intro__photo-tagline shrink-0 px-6 max-lg:pt-0 max-lg:pb-0 pt-2 pb-8 md:px-10 md:pb-9 lg:px-0 lg:pt-1.5 lg:pb-10" data-hero-piece>
      <span class="hero-intro__photo-tagline__text">Real Estate &amp; Renovation</span>
    </p>
  </div>
</section>

<!-- Story / Philosophy -->
<section class="bg-white overflow-hidden">

  <!-- Mobile -->
  <div class="story-mobile-block lg:hidden py-20 md:py-28 px-6 md:px-10">
    <div class="story-mobile-hero -mx-6 md:-mx-10 mb-8 overflow-hidden aspect-[3/1] max-h-[7rem]" data-reveal>
      <img src="/images/story/story-interior.webp" alt="リビング内観" class="w-full h-full object-cover object-center" width="600" height="900" loading="lazy" decoding="async">
    </div>
    <div class="mb-10" data-reveal data-delay="80">
      <p class="section-label mb-4">Our Story</p>
      <h2 class="font-serif text-2xl text-ink leading-tight text-balance">買って終わりじゃない、<br>不動産。</h2>
      <span class="mt-4 block h-px w-10 bg-[#E8621A]" aria-hidden="true"></span>
      <p class="mt-5 text-base leading-relaxed text-muted">不動産の失敗は、買った後に起きます。工務店と一体で、物件探しから売却まで責任を持って関わります。</p>
      <div class="mt-7">
        <a href="/story" class="site-btn site-btn--md site-btn--outline-ink">
          <span class="site-btn__inner">私たちの想い<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></span>
        </a>
